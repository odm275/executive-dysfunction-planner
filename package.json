{
  "name": "executive-dysfunction-planner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "check": "next lint && tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/server/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "dev": "next dev --turbo",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "lint": "SKIP_ENV_VALIDATION=1 next lint",
    "lint:fix": "SKIP_ENV_VALIDATION=1 next lint --fix",
    "preview": "next build && next start",
    "start": "next start",
    "test": "SKIP_ENV_VALIDATION=1 jest && playwright test",
    "test:watch": "SKIP_ENV_VALIDATION=1 jest --watch",
    "test:coverage": "SKIP_ENV_VALIDATION=1 jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "sandcastle": "tsx .sandcastle/main.ts",
    "sandcastle:build": "podman build -t sandcastle:executive-dysfunction-planner -f .sandcastle/Dockerfile .",
    "sandcastle:clean": "sh -c 'names=$(podman ps -a --filter name=sandcastle --format \"{{.Names}}\"); if [ -n \"$names\" ]; then echo \"$names\" | xargs podman rm -f; fi; echo \"Sandcastle containers cleaned.\"'",
    "sandcastle:reset": "sh -c 'names=$(podman ps -a --filter name=sandcastle --format \"{{.Names}}\"); if [ -n \"$names\" ]; then echo \"$names\" | xargs podman rm -f; fi; images=$(podman images sandcastle --format \"{{.Repository}}:{{.Tag}}\"); if [ -n \"$images\" ]; then echo \"$images\" | xargs podman rmi; fi; echo \"Removed. Rebuilding image...\"; podman build -t sandcastle:executive-dysfunction-planner -f .sandcastle/Dockerfile .'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-hero/sandcastle": "^0.4.5",
    "@ai-sdk/anthropic": "^1.2.12",
    "@auth/drizzle-adapter": "^1.7.2",
    "@libsql/client": "^0.14.0",
    "@t3-oss/env-nextjs": "^0.12.0",
    "@tanstack/react-query": "^5.69.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "ai": "^4.3.19",
    "better-auth": "^1.3",
    "drizzle-orm": "^0.41.0",
    "next": "^15.2.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "superjson": "^2.2.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.0.15",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.14.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "drizzle-kit": "^0.30.5",
    "eslint": "^9.23.0",
    "eslint-config-next": "^15.2.3",
    "eslint-plugin-drizzle": "^0.2.3",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.0.15",
    "tsx": "^4.20.6",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.27.0"
  },
  "ct3aMetadata": {
    "initVersion": "7.40.0"
  },
  "packageManager": "npm@10.9.2"
}
