{
  "name": "executive-dysfunction-planner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "check": "next lint && tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "bun src/server/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "dev": "next dev --turbo",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "lint": "SKIP_ENV_VALIDATION=1 next lint",
    "lint:fix": "SKIP_ENV_VALIDATION=1 next lint --fix",
    "preview": "next build && next start",
    "start": "next start",
    "test": "SKIP_ENV_VALIDATION=1 jest && playwright test",
    "test:watch": "SKIP_ENV_VALIDATION=1 jest --watch",
    "test:coverage": "SKIP_ENV_VALIDATION=1 jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "sandcastle": "bunx tsx .sandcastle/main.ts",
    "sandcastle:build": "bunx sandcastle docker build-image",
    "sandcastle:clean": "docker ps -a --filter name=sandcastle --format '{{.Names}}' | xargs -r docker rm -f && echo 'Sandcastle containers cleaned.'",
    "sandcastle:reset": "docker ps -a --filter name=sandcastle --format '{{.Names}}' | xargs -r docker rm -f && docker images sandcastle --format '{{.Repository}}:{{.Tag}}' | xargs -r docker rmi && echo 'Removed. Rebuilding image...' && bunx sandcastle docker build-image",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-hero/sandcastle": "^0.4.5",
    "@auth/drizzle-adapter": "^1.7.2",
    "@libsql/client": "^0.14.0",
    "@t3-oss/env-nextjs": "^0.12.0",
    "@tanstack/react-query": "^5.69.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "better-auth": "^1.3",
    "drizzle-orm": "^0.41.0",
    "next": "^15.2.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "superjson": "^2.2.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.0.15",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.14.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "drizzle-kit": "^0.30.5",
    "eslint": "^9.23.0",
    "eslint-config-next": "^15.2.3",
    "eslint-plugin-drizzle": "^0.2.3",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.0.15",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.27.0"
  },
  "ct3aMetadata": {
    "initVersion": "7.40.0"
  },
  "packageManager": "pnpm@9.12.3+sha512.cce0f9de9c5a7c95bef944169cc5dfe8741abfb145078c0d508b868056848a87c81e626246cb60967cbd7fd29a6c062ef73ff840d96b3c86c40ac92cf4a813ee"
}
